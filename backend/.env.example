# Django
DJANGO_ENV=local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database
# Recommended: PostgreSQL (same as production).
# 1) docker compose up -d
# 2) ./scripts/migrate-to-postgres.sh
# Or set manually:
DATABASE_URL=postgresql://turtlecruise:turtlecruise@localhost:5432/turtlecruise
# Leave empty only for quick SQLite smoke tests (not for staging/prod):
# DATABASE_URL=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Stripe
STRIPE_MODE=test
STRIPE_PUBLIC_KEY=REDACTED
STRIPE_SECRET_KEY=REDACTED
STRIPE_WEBHOOK_SECRET=REDACTED

# Brevo email delivery (API preferred; SMTP fallback)
BREVO_API_KEY=REDACTED
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=REDACTED
BREVO_SMTP_PASSWORD=REDACTED
BREVO_SENDER_EMAIL=book@turtlecruisecyprus.com
BREVO_SENDER_NAME=Turtle Cruise Cyprus
ADMIN_EMAIL_RECIPIENTS=book@turtlecruisecyprus.com

# ClickSend SMS (REST API only — not for email tickets; paid per SMS)
CLICKSEND_USERNAME=REDACTED
CLICKSEND_API_KEY=REDACTED
CLICKSEND_SENDER_ID=REDACTED
ADMIN_SMS_RECIPIENTS=

# Admin instant alert when booking confirmed: sms (ClickSend, default) | telegram | both | none
ADMIN_NOTIFY_CHANNEL=sms
TELEGRAM_BOT_TOKEN=REDACTED
TELEGRAM_ADMIN_CHAT_IDS=

# Stripe test keys (auto-used when STRIPE_MODE=test)
STRIPE_TEST_PUBLIC_KEY=REDACTED
STRIPE_TEST_SECRET_KEY=REDACTED

# Booking defaults
BOOKING_OVERBOOK_TOLERANCE=1
SITE_BASE_URL=http://localhost:8000
GTM_CONTAINER_ID=GTM-K63GCMLB

# Hero rating (fallback without API). Auto-fetch when GOOGLE_PLACES_API_KEY is set.
GOOGLE_RATING_SCORE=4.9
GOOGLE_REVIEW_COUNT=840
GOOGLE_MAPS_URL=https://www.google.com/maps?q=34.9811233,34.0032025
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJ0fyYD0LF3xQREt9gKpNwvU4

# nginx + Let's Encrypt (только с --profile bundled-nginx)
DOMAIN=turtlecruisecyprus.solovey-desert.by
CERTBOT_EMAIL=your-email@example.com

# Общий VPS (внешний nginx на 80/443, boomerang на 8000):
WEB_HOST_PORT=8001
# media из git: docker-compose монтирует ./media → /app/media (менять не нужно)

# --- .env на сервере ---
# DJANGO_ALLOWED_HOSTS=turtlecruisecyprus.solovey-desert.by,localhost
# DJANGO_CSRF_TRUSTED_ORIGINS=https://turtlecruisecyprus.solovey-desert.by
# SITE_BASE_URL=https://turtlecruisecyprus.solovey-desert.by
# Запуск на сервере: docker compose up -d --build
# Stripe webhook: https://turtlecruisecyprus.solovey-desert.by/api/v1/payments/stripe/webhook/
SUPPORT_EMAIL=book@turtlecruisecyprus.com
SUPPORT_PHONE=+35797719450
MEETING_POINT=Ayia Napa Harbour (Limanaki)
# Fixed pin (same as WP goo.gl/QSLFqUoDX8rCtAsz7) — prefer coords over short links.
MEETING_POINT_MAPS_URL=https://www.google.com/maps?q=34.9811233,34.0032025

# WordPress migration
WP_SQL_DUMP_PATH=../turtlecruisebyscubacat/dup-installer/dup-database__46e869c-06090919.sql
